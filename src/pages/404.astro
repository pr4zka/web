---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---
<BaseLayout title="404 — Página no encontrada" description="Página no encontrada">
  <div class="container" style="text-align: center; padding: 4rem 0;">
    <h1 style="font-size: 4rem; margin-bottom: 0.5rem;">404</h1>
    <p style="font-size: 1.25rem; margin-bottom: 2rem;">Página no encontrada</p>
    <a href={base} class="view-all">&larr; Volver al inicio</a>
  </div>
</BaseLayout>
