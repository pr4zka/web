---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const formatDate = (date: Date) =>
  date.toLocaleDateString('es-PY', { day: 'numeric', month: 'long', year: 'numeric' });

const base = import.meta.env.BASE_URL;
---
<BaseLayout title="Blog — ~/ivan martinez" description="Artículos de Ivan Martinez">
  <div class="container">
    <h1 class="section-heading">Blog</h1>
    {posts.length === 0 ? (
      <p>Nada por aquí aún.</p>
    ) : (
      <ul class="writing-list">
        {posts.map((post) => (
          <li>
            <a href={`${base}blog/${post.id}/`} class="writing-item">
              <span class="writing-title">{post.data.title}</span>
              <span class="writing-meta">{formatDate(post.data.date)}</span>
              <p class="writing-desc">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>
